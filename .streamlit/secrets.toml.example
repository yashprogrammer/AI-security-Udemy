# Copy this file to `.streamlit/secrets.toml` and fill in real values for LOCAL runs.
# On Streamlit Community Cloud, paste these same keys into the app's
# Settings → Secrets box instead (do NOT commit the real secrets.toml).

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Guardrails Hub token (free) — https://hub.guardrailsai.com
# Needed to install the DetectPII / CompetitorCheck Hub validators.
# If omitted, the app falls back to regex/substring matchers and still runs.
GUARDRAILS_TOKEN = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
